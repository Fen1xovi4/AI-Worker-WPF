<UserControl x:Class="WpfBrowserWorker.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ColorBackground}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="System Logs" FontSize="22" FontWeight="SemiBold"
                       FontFamily="Segoe UI" Foreground="{StaticResource ColorTextPrimary}"/>
            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                    Content="Clear" Command="{Binding ClearCommand}"/>
        </Grid>

        <Border Grid.Row="1" Background="#1D2026"
                CornerRadius="6" BorderBrush="{StaticResource ColorBorder}" BorderThickness="1">
            <ListBox x:Name="LogList" ItemsSource="{Binding Entries}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     Padding="12,8" FontFamily="Consolas" FontSize="12">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}"
                                       Foreground="#4B5263" Margin="0,0,12,0" Width="58"/>
                            <TextBlock Text="{Binding Level}" Width="38"
                                       Foreground="{Binding LevelColor}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Message}" Foreground="#ABB2BF"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0,1"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>
    </Grid>
</UserControl>
