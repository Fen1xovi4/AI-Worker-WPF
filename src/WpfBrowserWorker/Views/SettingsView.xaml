<UserControl x:Class="WpfBrowserWorker.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ColorBackground}">
    <ScrollViewer Padding="24">
        <StackPanel MaxWidth="560" HorizontalAlignment="Left">

            <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold"
                       FontFamily="Segoe UI" Foreground="{StaticResource ColorTextPrimary}"
                       Margin="0,0,0,24"/>

            <!-- Connection -->
            <Border Background="{StaticResource ColorSurface}" CornerRadius="6"
                    BorderBrush="{StaticResource ColorBorder}" BorderThickness="1"
                    Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Connection" FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Foreground="{StaticResource ColorPrimary}"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Backend URL" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding BackendUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                    <TextBlock Text="API Key (wk_...)" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="ApiKeyBox" Margin="0,0,0,14"/>

                    <TextBlock Text="Worker ID" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding WorkerId, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>

            <!-- Performance -->
            <Border Background="{StaticResource ColorSurface}" CornerRadius="6"
                    BorderBrush="{StaticResource ColorBorder}" BorderThickness="1"
                    Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Performance" FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Foreground="{StaticResource ColorPrimary}"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Poll Interval (ms)" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding PollIntervalMs, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                    <TextBlock Text="Max Browsers" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding MaxBrowsers, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                    <TextBlock Text="Chromium Path (leave empty for auto-detect)" FontSize="12"
                               FontFamily="Segoe UI"
                               Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding ChromiumPath, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>

            <!-- Options -->
            <Border Background="{StaticResource ColorSurface}" CornerRadius="6"
                    BorderBrush="{StaticResource ColorBorder}" BorderThickness="1"
                    Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Options" FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Foreground="{StaticResource ColorPrimary}"
                               Margin="0,0,0,16"/>

                    <CheckBox IsChecked="{Binding HumanMode}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Human Mode" FontFamily="Segoe UI" FontSize="13"
                                       Foreground="{StaticResource ColorTextPrimary}"/>
                            <TextBlock Text="Adds random delays to simulate human behavior"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="{StaticResource ColorTextSecondary}"/>
                        </StackPanel>
                    </CheckBox>

                    <CheckBox IsChecked="{Binding AutoStart}">
                        <TextBlock Text="Auto-start on launch" FontFamily="Segoe UI" FontSize="13"
                                   Foreground="{StaticResource ColorTextPrimary}"/>
                    </CheckBox>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Style="{StaticResource PrimaryButton}" Content="Save Settings"
                        Command="{Binding SaveCommand}" Margin="0,0,10,0"/>
                <Button Style="{StaticResource SecondaryButton}" Content="Test Connection"
                        Command="{Binding TestConnectionCommand}"/>
            </StackPanel>

            <TextBlock Text="{Binding TestResult}" FontSize="12" FontFamily="Segoe UI"
                       Foreground="{StaticResource ColorTextSecondary}"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
