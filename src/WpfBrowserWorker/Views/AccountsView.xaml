<UserControl x:Class="WpfBrowserWorker.Views.AccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ColorBackground}">
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left panel: account list + create form -->
            <ColumnDefinition Width="320" MinWidth="260"/>
            <ColumnDefinition Width="8"/>
            <!-- Right panel: selected account details -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LEFT: Account list ════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="24,24,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Accounts" FontSize="22" FontWeight="SemiBold"
                       FontFamily="Segoe UI" Foreground="{StaticResource ColorTextPrimary}"
                       Margin="0,0,0,16"/>

            <!-- Create account form -->
            <Border Grid.Row="1" Background="{StaticResource ColorSurface}" CornerRadius="6"
                    BorderBrush="{StaticResource ColorBorder}" BorderThickness="1"
                    Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="New Account" FontSize="12" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Foreground="{StaticResource ColorPrimary}"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Username" FontSize="11" FontFamily="Segoe UI"
                               Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewAccountUsername, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"/>

                    <TextBlock Text="Chrome Profile" FontSize="11" FontFamily="Segoe UI"
                               Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding NewAccountProfile}"
                              DisplayMemberPath="Name"
                              Margin="0,0,0,10"/>

                    <TextBlock Text="Notes (optional)" FontSize="11" FontFamily="Segoe UI"
                               Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewAccountNotes, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <Button Style="{StaticResource PrimaryButton}" Content="Create Account"
                            Command="{Binding CreateAccountCommand}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Account list -->
            <Border Grid.Row="2" Background="{StaticResource ColorSurface}" CornerRadius="6"
                    BorderBrush="{StaticResource ColorBorder}" BorderThickness="1">
                <ListView ItemsSource="{Binding Accounts}"
                          SelectedItem="{Binding SelectedAccount}"
                          BorderThickness="0" Background="Transparent">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Username}" FontSize="13"
                                               FontFamily="Segoe UI"
                                               Foreground="{StaticResource ColorTextPrimary}"/>
                                    <TextBlock Text="{Binding Status}" FontSize="11"
                                               FontFamily="Segoe UI"
                                               Foreground="{StaticResource ColorTextSecondary}"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="✕" FontSize="10"
                                        Style="{StaticResource SecondaryButton}" Padding="6,2"
                                        Command="{Binding DataContext.DeleteAccountCommand,
                                            RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- Status message -->
            <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" FontSize="11"
                       FontFamily="Segoe UI" Foreground="{StaticResource ColorTextSecondary}"
                       TextWrapping="Wrap" Margin="0,8,0,0"/>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Column="1" Fill="{StaticResource ColorBorder}" Width="1" Margin="0,24"/>

        <!-- ══ RIGHT: Selected account detail ════════════════════════════════ -->
        <ScrollViewer Grid.Column="2" Margin="16,24,24,24" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Detail panel (visible when account selected) -->
                <StackPanel Visibility="{Binding SelectedAccount,
                                Converter={StaticResource NullToCollapsed}}">

                    <!-- Account info header -->
                    <TextBlock FontSize="18" FontWeight="SemiBold" FontFamily="Segoe UI"
                               Foreground="{StaticResource ColorTextPrimary}" Margin="0,0,0,4">
                        <TextBlock.Text>
                            <Binding Path="SelectedAccount.Username"/>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock FontSize="12" FontFamily="Segoe UI"
                               Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,20">
                        <TextBlock.Text>
                            <Binding Path="SelectedAccount.Notes"/>
                        </TextBlock.Text>
                    </TextBlock>

                    <!-- Pages section -->
                    <Border Background="{StaticResource ColorSurface}" CornerRadius="6"
                            BorderBrush="{StaticResource ColorBorder}" BorderThickness="1"
                            Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Linked Pages" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{StaticResource ColorPrimary}"
                                       Margin="0,0,0,12"/>

                            <!-- Add page row -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding NewPageUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="https://www.instagram.com/"/>
                                <TextBox Grid.Column="2"
                                         Text="{Binding NewPageLabel, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="Label"/>
                                <ComboBox Grid.Column="4"
                                          SelectedValue="{Binding NewPageLanguage}"
                                          ToolTip="Language for AI content">
                                    <ComboBoxItem Content="ru"/>
                                    <ComboBoxItem Content="en"/>
                                    <ComboBoxItem Content="de"/>
                                    <ComboBoxItem Content="fr"/>
                                    <ComboBoxItem Content="es"/>
                                </ComboBox>
                                <Button Grid.Column="6"
                                        Style="{StaticResource PrimaryButton}" Content="Add"
                                        Command="{Binding AddPageCommand}"/>
                            </Grid>

                            <!-- Pages list -->
                            <Border Background="{StaticResource ColorSurfaceLow}" CornerRadius="4"
                                    BorderBrush="{StaticResource ColorBorder}" BorderThickness="1"
                                    MaxHeight="200">
                                <ListView ItemsSource="{Binding Pages}"
                                          SelectedItem="{Binding SelectedPage}"
                                          BorderThickness="0" Background="Transparent">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Platform" Width="90"
                                                            DisplayMemberBinding="{Binding Platform}"/>
                                            <GridViewColumn Header="URL" Width="280"
                                                            DisplayMemberBinding="{Binding Url}"/>
                                            <GridViewColumn Header="Label" Width="100"
                                                            DisplayMemberBinding="{Binding Label}"/>
                                            <GridViewColumn Header="Lang" Width="45"
                                                            DisplayMemberBinding="{Binding Language}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Border>

                            <Button Style="{StaticResource SecondaryButton}"
                                    Content="Remove Selected" HorizontalAlignment="Left"
                                    Margin="0,8,0,0"
                                    Command="{Binding RemovePageCommand}"
                                    CommandParameter="{Binding SelectedPage}"/>
                        </StackPanel>
                    </Border>

                    <!-- Telegram Bot section -->
                    <Border Background="{StaticResource ColorSurface}" CornerRadius="6"
                            BorderBrush="{StaticResource ColorBorder}" BorderThickness="1"
                            Padding="16" Margin="0,0,0,0">
                        <StackPanel>
                            <!-- Header row: title + status badge -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Telegram Bot" FontSize="13"
                                           FontWeight="SemiBold" FontFamily="Segoe UI"
                                           Foreground="{StaticResource ColorPrimary}"/>
                                <Border Grid.Column="1" CornerRadius="4" Padding="8,3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#3E4451"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BotIsRunning}" Value="True">
                                                    <Setter Property="Background" Value="#2D6A2D"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding BotStatus}" FontSize="11"
                                               FontFamily="Segoe UI" Foreground="White"/>
                                </Border>
                            </Grid>

                            <!-- Bot username display -->
                            <TextBlock FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,10"
                                       Foreground="{StaticResource ColorTextSecondary}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Нет подключённого бота"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BotConfigured}" Value="True">
                                                <Setter Property="Text" Value="{Binding BotUsername}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Token input -->
                            <TextBlock Text="Bot Token (из @BotFather)" FontSize="11"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource ColorTextSecondary}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewBotToken, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <!-- Action buttons -->
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource PrimaryButton}"
                                        Content="Подключить"
                                        Command="{Binding SaveBotCommand}"
                                        Margin="0,0,8,0"/>
                                <Button Command="{Binding ToggleBotCommand}"
                                        Margin="0,0,8,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Setter Property="Content" Value="Запустить"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BotIsRunning}" Value="True">
                                                    <Setter Property="Content" Value="Остановить"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding BotConfigured}" Value="False">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Удалить"
                                        Command="{Binding RemoveBotCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BotConfigured}" Value="False">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
