<UserControl x:Class="WpfBrowserWorker.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ColorBackground}">
    <ScrollViewer Padding="24">
        <StackPanel>

            <!-- Page Title -->
            <TextBlock Text="Dashboard" FontSize="22" FontWeight="SemiBold"
                       FontFamily="Segoe UI" Foreground="{StaticResource ColorTextPrimary}"
                       Margin="0,0,0,20"/>

            <!-- Stat Cards -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- DONE -->
                <Border Grid.Column="0" Background="{StaticResource ColorSurface}"
                        CornerRadius="6" Padding="20,16" Margin="0,0,12,0"
                        BorderBrush="{StaticResource ColorBorder}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Tasks Done" FontSize="11" FontFamily="Segoe UI"
                                   Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TasksDone}" FontSize="32" FontWeight="Bold"
                                   FontFamily="Segoe UI" Foreground="{StaticResource ColorSuccess}"/>
                    </StackPanel>
                </Border>

                <!-- FAILED -->
                <Border Grid.Column="1" Background="{StaticResource ColorSurface}"
                        CornerRadius="6" Padding="20,16" Margin="0,0,12,0"
                        BorderBrush="{StaticResource ColorBorder}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Failed" FontSize="11" FontFamily="Segoe UI"
                                   Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TasksFailed}" FontSize="32" FontWeight="Bold"
                                   FontFamily="Segoe UI" Foreground="{StaticResource ColorError}"/>
                    </StackPanel>
                </Border>

                <!-- ACTIVE -->
                <Border Grid.Column="2" Background="{StaticResource ColorSurface}"
                        CornerRadius="6" Padding="20,16" Margin="0,0,12,0"
                        BorderBrush="{StaticResource ColorBorder}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Active" FontSize="11" FontFamily="Segoe UI"
                                   Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TasksActive}" FontSize="32" FontWeight="Bold"
                                   FontFamily="Segoe UI" Foreground="{StaticResource ColorRunning}"/>
                    </StackPanel>
                </Border>

                <!-- BROWSERS -->
                <Border Grid.Column="3" Background="{StaticResource ColorSurface}"
                        CornerRadius="6" Padding="20,16" Margin="0"
                        BorderBrush="{StaticResource ColorBorder}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Browsers" FontSize="11" FontFamily="Segoe UI"
                                   Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ActiveBrowsers.Count}" FontSize="32" FontWeight="Bold"
                                   FontFamily="Segoe UI" Foreground="{StaticResource ColorPrimary}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Active Browsers -->
            <TextBlock Text="Active Browsers" FontSize="14" FontWeight="SemiBold"
                       FontFamily="Segoe UI" Foreground="{StaticResource ColorTextPrimary}"
                       Margin="0,0,0,10"/>

            <Border Background="{StaticResource ColorSurface}" CornerRadius="6"
                    Padding="16" BorderBrush="{StaticResource ColorBorder}" BorderThickness="1">
                <ItemsControl ItemsSource="{Binding ActiveBrowsers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="6" Height="6"
                                         Fill="{StaticResource ColorPrimary}"
                                         VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Username}"
                                           FontFamily="Segoe UI" FontSize="13" Margin="10,0,0,0"
                                           Foreground="{StaticResource ColorTextPrimary}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Platform}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{StaticResource ColorTextSecondary}"
                                           Margin="0,0,16,0"/>
                                <TextBlock Grid.Column="3" Text="{Binding Status}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{StaticResource ColorRunning}"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveBrowsers.Count}" Value="0">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate>
                                                <TextBlock Text="No active browsers"
                                                           FontFamily="Segoe UI" FontSize="13"
                                                           Foreground="{StaticResource ColorTextSecondary}"
                                                           HorizontalAlignment="Center" Padding="0,16"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                </ItemsControl>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
