<Window x:Class="WpfBrowserWorker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="AI Browser Worker" Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#21252B"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        FontFamily="Segoe UI">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="5"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="#3E4451" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Title Bar ── -->
            <Grid Grid.Row="0" Background="#21252B">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: icon + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="14,0,0,0">
                    <Ellipse Width="10" Height="10" Fill="#61AFEF" Margin="0,0,10,0"/>
                    <TextBlock Text="AI Browser Worker" FontFamily="Segoe UI"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#ABB2BF" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Center: worker id -->
                <TextBlock Grid.Column="1" Text="{Binding WorkerId}"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="#4B5263"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Right: window controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource TitleBarButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MinimizeBtn_Click" ToolTip="Minimize">─</Button>
                    <Button Style="{StaticResource TitleBarButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MaximizeBtn_Click" ToolTip="Maximize">□</Button>
                    <Button Style="{StaticResource TitleBarCloseButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="CloseBtn_Click" ToolTip="Close">✕</Button>
                </StackPanel>
            </Grid>

            <!-- ── Status Bar ── -->
            <Border Grid.Row="1" Background="{Binding StatusBarColor}"
                    BorderBrush="#3E4451" BorderThickness="0,0,0,1">
                <Grid Margin="14,0" Height="26">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="{Binding ConnectionDot}" Margin="0,0,7,0"/>
                        <TextBlock Text="{Binding WorkerStatus}" Foreground="#ABB2BF"
                                   FontFamily="Segoe UI" FontSize="11"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2" Text="{Binding AppVersion}"
                               Foreground="#4B5263" FontFamily="Segoe UI" FontSize="11"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ── Main Layout ── -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Nav Rail -->
                <Border Grid.Column="0" Background="#21252B"
                        BorderBrush="#3E4451" BorderThickness="0,0,1,0">
                    <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                        <Button Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                                ToolTip="Dashboard">⬛</Button>
                        <Button Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" CommandParameter="Tasks"
                                ToolTip="Tasks">≡</Button>
                        <Button Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" CommandParameter="Accounts"
                                ToolTip="Accounts">👤</Button>
                        <Button Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" CommandParameter="Logs"
                                ToolTip="Logs">📋</Button>
                        <Button Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" CommandParameter="Settings"
                                ToolTip="Settings">⚙</Button>
                    </StackPanel>
                </Border>

                <!-- Content Area -->
                <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
